        "config": {
          "choices": {
            "hero_banner": { "type": "SharedSlice" },
            "rich_text": { "type": "SharedSlice" },
            "video_embed": { "type": "SharedSlice" },
            "image_block": { "type": "SharedSlice" }
          }
        }
      }
    }
  }
}
